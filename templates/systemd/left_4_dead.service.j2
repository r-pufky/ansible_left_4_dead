[Unit]
Description=Left 4 Dead Dedicated Server.
After=network.target
Wants=network.target

[Service]
Type=simple
{% if left_4_dead_flg_update %}
ExecStartPre={{ left_4_dead___app._steamcmd }} +app_update {{ left_4_dead___release._app_id }} {{ left_4_dead__srv._update_opts }} +quit
{% endif %}
ExecStart={{ left_4_dead___app._bin }} +console +game left4dead {{ left_4_dead__srv._launch_opts }} +exec server.cfg +pidfile /tmp/left_4_dead.pid
WorkingDirectory={{ left_4_dead___app._root_d }}
PidFile=/run/left_4_dead.pid
TimeoutStartSec=infinity
Restart=always
# limitNOFILE default is 524288 in Trixie.
Environment="LD_LIBRARY_PATH={{ left_4_dead___app._root_d }}:{{ left_4_dead___app._root_d }}/bin"
User={{ steam__ctx._user }}
Group={{ steam__ctx._group }}

[Install]
WantedBy=multi-user.target